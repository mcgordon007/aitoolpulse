---
import BaseLayout from '@/layouts/BaseLayout'
import TitlePage from '@/components/TitlePage'
import { getTags } from '@/utils'
import { getLangFromUrl, useTranslations } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const tags = await getTags()

// Sort alphabetically
const sortedTags = [...tags].sort((a, b) => a.name.localeCompare(b.name))

// Group by first letter
const groupedTags: Record<string, typeof tags> = {}
sortedTags.forEach(tag => {
  const firstLetter = tag.name[0].toUpperCase()
  if (!groupedTags[firstLetter]) {
    groupedTags[firstLetter] = []
  }
  groupedTags[firstLetter].push(tag)
})

const letters = Object.keys(groupedTags).sort()

const tagColors = [
  '#60a5fa', '#818cf8', '#a78bfa', '#c084fc', '#e879f9',
  '#f472b6', '#fb7185', '#fb923c', '#fbbf24', '#a3e635',
  '#34d399', '#2dd4bf', '#22d3ee', '#38bdf8',
]

const getColor = (index: number) => tagColors[index % tagColors.length]
---

<BaseLayout title="All Tags">
  <TitlePage title="All Tags" />
  
  <div class="tags-page-wrapper">
    <!-- Alphabet Navigation -->
    <div class="alphabet-nav">
      {letters.map(letter => (
        <a href={`#letter-${letter}`} class="alphabet-link">{letter}</a>
      ))}
    </div>
    
    <!-- Tags List -->
    <div class="tags-list">
      {letters.map(letter => (
        <div class="letter-group" id={`letter-${letter}`}>
          <h2 class="letter-heading">{letter}</h2>
          <div class="tags-grid">
            {groupedTags[letter].map((tag, index) => (
              <a
                href={`/tags/${encodeURIComponent(tag.name.toLowerCase())}`}
                class="tag-card"
                style={`--color: ${getColor(index)}`}
              >
                <span class="tag-name">{tag.name}</span>
                <span class="tag-count">{tag.count} {tag.count === 1 ? 'article' : 'articles'}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .tags-page-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .alphabet-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 3rem;
    padding: 1rem;
    background: #1f2937;
    border-radius: 12px;
    position: sticky;
    top: 1rem;
    z-index: 100;
  }

  .alphabet-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: #374151;
    color: #f3f4f6;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .alphabet-link:hover {
    background: #4b5563;
    transform: translateY(-2px);
  }

  .tags-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .letter-group {
    scroll-margin-top: 100px;
  }

  .letter-heading {
    font-size: 2rem;
    font-weight: 700;
    color: #f3f4f6;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #374151;
  }

  .tags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .tag-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--color) 0%, var(--color)dd 100%);
    color: #fff;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .tag-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }

  .tag-name {
    font-size: 1rem;
    font-weight: 600;
  }

  .tag-count {
    font-size: 0.75rem;
    background: rgba(255,255,255,0.2);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }

  @media (max-width: 640px) {
    .alphabet-nav {
      gap: 0.375rem;
      padding: 0.75rem;
    }

    .alphabet-link {
      width: 32px;
      height: 32px;
      font-size: 0.8rem;
    }

    .tags-grid {
      grid-template-columns: 1fr;
    }

    .letter-heading {
      font-size: 1.5rem;
    }
  }
</style>
