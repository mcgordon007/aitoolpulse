---
import { siteConfig } from '@/site-config'
import path from 'node:path'
import { AstroFont } from 'astro-font'
import SEO from './SEO.astro'

export interface Props {
  title: string
  description?: string
  ogImage?: string | undefined
  articleDate?: string | undefined
  tags?: string[]
}

const {
  title,
  description = siteConfig.description,
  ogImage,
  articleDate,
  tags = [],
}: Props = Astro.props

const canonicalHref =
  Astro.site != null
    ? new URL(Astro.url.pathname, Astro.site).href
    : Astro.url.href
const socialImageHref = new URL(ogImage ?? '/open-graph.png', Astro.url).href

const titleSeparator = '•'

const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`

const fontPath = (fileName: string) =>
  path.resolve(import.meta.dirname, '../../public/fonts', fileName)
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />

<!-- SEO Enhanced -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1" />
<link rel="author" href="/about" />

<!-- JSON-LD Structured Data -->
<SEO 
  type={articleDate ? 'article' : 'website'}
  title={title}
  description={description}
  url={canonicalHref}
  image={socialImageHref}
  datePublished={articleDate}
  tags={tags}
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHref} />

<!-- Primary Meta Tags -->
<title>{siteTitle}</title>

<!-- SEO -->
<meta name="title" content={siteTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />
<meta name="keywords" content={tags.length > 0 ? tags.join(', ') : 'AI tools, artificial intelligence, GPT, Claude, OpenAI, Anthropic, machine learning, LLM, chatbot, AI news, AI reviews, AI comparison, productivity tools, automation, coding assistant'} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={articleDate ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageHref} />
<meta property="og:locale" content={siteConfig.ogLocale} />
{
  articleDate && (
    <>
      <meta property="article:author" content={siteConfig.author} />
      <meta property="article:published_time" content={articleDate} />
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageHref} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS auto-discovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={siteConfig.title}
  href="/rss.xml"
/>

<AstroFont
  config={[
    {
      preload: false,
      display: 'swap',
      name: 'Manrope',
      fallback: 'sans-serif',
      src: [
        {
          weight: '200',
          style: 'normal',
          path: fontPath('Manrope-ExtraLight.woff2'),
        },
        {
          weight: '300',
          style: 'normal',
          path: fontPath('Manrope-Light.woff2'),
        },
        {
          weight: '400',
          style: 'normal',
          path: fontPath('Manrope-Regular.woff2'),
        },
        {
          weight: '500',
          style: 'normal',
          path: fontPath('Manrope-Medium.woff2'),
        },
        {
          weight: '600',
          style: 'normal',
          path: fontPath('Manrope-SemiBold.woff2'),
        },
        {
          weight: '700',
          preload: true,
          style: 'normal',
          path: fontPath('Manrope-Bold.woff2'),
        },
        {
          weight: '800',
          style: 'normal',
          path: fontPath('Manrope-ExtraBold.woff2'),
        },
      ],
    },
  ]}
/>
