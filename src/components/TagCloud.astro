---
interface Tag {
  name: string;
  count: number;
}

interface Props {
  tags: Tag[];
}

const { tags } = Astro.props;

// Sort by count descending and take top 12
const sortedTags = [...tags].sort((a, b) => b.count - a.count).slice(0, 12);

const tagColors = [
  '#60a5fa', '#818cf8', '#a78bfa', '#c084fc', '#e879f9',
  '#f472b6', '#fb7185', '#fb923c', '#fbbf24', '#a3e635',
  '#34d399', '#2dd4bf', '#22d3ee', '#38bdf8',
];

const getColor = (index: number) => tagColors[index % tagColors.length];
---

<div class="tag-cloud-wrapper">
  <div class="section-header">
    <h2 class="section-title">Popular Tags</h2>
    <span class="tag-count">{sortedTags.length} of {tags.length} tags</span>
  </div>
  
  <div class="scroll-container">
    <div class="tags-scroll">
      {sortedTags.map((tag, index) => (
        <a
          href={`/tags/${encodeURIComponent(tag.name.toLowerCase())}`}
          class="tag-item"
          style={`--color: ${getColor(index)}`}
        >
          <span class="tag-name">{tag.name}</span>
          <span class="tag-badge">{tag.count}</span>
        </a>
      ))}
    </div>
  </div>
  
  <div class="view-all-section">
    <a href="/tags/all" class="view-all-link">
      <span>View All Tags</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .tag-cloud-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 0 0.5rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f3f4f6;
  }

  .tag-count {
    font-size: 0.875rem;
    color: #9ca3af;
  }

  .scroll-container {
    position: relative;
    margin: 0 -1rem;
    padding: 0 1rem;
  }

  .scroll-container::before,
  .scroll-container::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40px;
    z-index: 10;
    pointer-events: none;
  }

  .scroll-container::before {
    left: 0;
    background: linear-gradient(to right, #111827, transparent);
  }

  .scroll-container::after {
    right: 0;
    background: linear-gradient(to left, #111827, transparent);
  }

  .tags-scroll {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 1rem 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: #4b5563 #1f2937;
  }

  .tags-scroll::-webkit-scrollbar {
    height: 6px;
  }

  .tags-scroll::-webkit-scrollbar-track {
    background: #1f2937;
    border-radius: 3px;
  }

  .tags-scroll::-webkit-scrollbar-thumb {
    background: #4b5563;
    border-radius: 3px;
  }

  .tags-scroll::-webkit-scrollbar-thumb:hover {
    background: #6b7280;
  }

  .tag-item {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 9999px;
    background: var(--color);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
  }

  .tag-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    filter: brightness(1.1);
  }

  .tag-badge {
    font-size: 0.75rem;
    background: rgba(255,255,255,0.2);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  .view-all-section {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    background: #374151;
    color: #f3f4f6;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .view-all-link:hover {
    background: #4b5563;
    transform: translateY(-1px);
  }

  .view-all-link svg {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 640px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .tag-item {
      padding: 0.5rem 0.875rem;
      font-size: 0.8rem;
    }
  }
</style>
