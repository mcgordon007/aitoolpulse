---
// Cookie Consent Banner for GDPR/CCPA compliance
---

<div id="cookie-banner" class="cookie-banner" style="display: none;">
  <div class="cookie-content">
    <p>
      We use cookies to enhance your browsing experience, serve personalized ads, and analyze our traffic. 
      By clicking "Accept All", you consent to our use of cookies. 
      <a href="/privacy">Learn more</a>
    </p>
    <div class="cookie-buttons">
      <button id="cookie-accept" class="cookie-btn accept">Accept All</button>
      <button id="cookie-decline" class="cookie-btn decline">Decline</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #1f2937;
    color: #f3f4f6;
    padding: 1rem;
    z-index: 9999;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.3);
  }

  .cookie-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cookie-content p {
    flex: 1;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .cookie-content a {
    color: #60a5fa;
    text-decoration: underline;
  }

  .cookie-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .cookie-btn {
    padding: 0.5rem 1.5rem;
    border-radius: 0.375rem;
    border: none;
    cursor: pointer;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .cookie-btn:hover {
    opacity: 0.9;
  }

  .cookie-btn.accept {
    background: #3b82f6;
    color: white;
  }

  .cookie-btn.decline {
    background: transparent;
    color: #9ca3af;
    border: 1px solid #4b5563;
  }

  @media (max-width: 640px) {
    .cookie-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  (function() {
    const COOKIE_CONSENT_KEY = 'cookie-consent';
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const declineBtn = document.getElementById('cookie-decline');

    // Check if user has already made a choice
    const consent = localStorage.getItem(COOKIE_CONSENT_KEY);
    
    if (!consent) {
      // Show banner after a short delay
      setTimeout(() => {
        if (banner) banner.style.display = 'block';
      }, 1000);
    }

    // Accept all cookies
    acceptBtn?.addEventListener('click', () => {
      localStorage.setItem(COOKIE_CONSENT_KEY, 'accepted');
      if (banner) banner.style.display = 'none';
      // Enable ads
      document.body.dataset.adsEnabled = 'true';
    });

    // Decline non-essential cookies
    declineBtn?.addEventListener('click', () => {
      localStorage.setItem(COOKIE_CONSENT_KEY, 'declined');
      if (banner) banner.style.display = 'none';
      // Disable personalized ads
      document.body.dataset.adsEnabled = 'false';
    });
  })();
</script>
